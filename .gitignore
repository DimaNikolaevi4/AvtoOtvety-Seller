```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*
requirements.txt.bak

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
.coverage
htmlcov/
.coverage.*

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# OS generated files
.DS_Store
Thumbs.db
```