PassengerEnabled On

# ВНИМАНИЕ: Замените путь ниже на ваш актуальный путь на BeGet
# Узнать текущий путь можно командой `pwd` в терминале хостинга
PassengerAppRoot /home/USERNAME/PATH_TO_PROJECT

# Проверьте версию Python в названии папки (3.10, 3.8 и т.д.)
PassengerPython /home/USERNAME/PATH_TO_PROJECT/venv/bin/python3.10

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|config\.py|passenger_wsgi\.py)$">
    Order allow,deny
    Deny from all
</FilesMatch>
