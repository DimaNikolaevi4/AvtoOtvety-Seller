# ==========================================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ (FLASK)
# ==========================================
# Секретный ключ для сессий и CSRF. Сгенерируйте новый для продакшена!
# В терминале: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_secure_random_string_in_production

# Режим отладки. На хостинге должно быть False!
FLASK_ENV=production
DEBUG=False

# Домен вашего сайта (без протокола, например: mysite.ru)
DOMAIN_NAME=mysite.ru

# ==========================================
# БАЗА ДАННЫХ (SQLite для примера)
# ==========================================
# Путь к базе данных. На хостинге лучше использовать абсолютный путь или папку instance/
# Пример: sqlite:///instance/prod.db
DATABASE_URL=sqlite:///dev.db

# ==========================================
# YANDEX OAUTH (АВТОРИЗАЦИЯ)
# ==========================================
# Данные из кабинета разработчика Яндекс
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URI=https://ваш-домен.ru/callback/yandex

# ==========================================
# EMAIL РАССЫЛКА (SMTP)
# ==========================================
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USERNAME=your_email@yandex.ru
MAIL_PASSWORD=your_app_password_not_main_password
MAIL_DEFAULT_SENDER=your_email@yandex.ru

# ==========================================
# TELEGRAM BOT (УВЕДОМЛЕНИЯ)
# ==========================================
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_or_group_id

# ==========================================
# БЕЗОПАСНОСТЬ И КАПЧА
# ==========================================
# Ключи для Google reCAPTCHA v2 или v3
RECAPTCHA_PUBLIC_KEY=your_recaptcha_site_key
RECAPTCHA_PRIVATE_KEY=your_recaptcha_secret_key

# ==========================================
# ПРОЧЕЕ
# ==========================================
# Максимальный размер загружаемого файла (в байтах), например 16MB
MAX_CONTENT_LENGTH=16777216
